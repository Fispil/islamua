{
  "expo": {
    "name": "Islam UA",
    "slug": "islam-ua",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "islamua",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,

    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1B2A"
    },

    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.maksymstorozhuk.islamua",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Islam UA використовує ваше місцезнаходження для розрахунку точного часу молитов та напрямку Кібли.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Islam UA використовує ваше місцезнаходження для надання точного часу молитов.",
        "NSLocationAlwaysUsageDescription": "Islam UA використовує ваше місцезнаходження для часу молитов у фоновому режимі.",
        "UIBackgroundModes": ["fetch", "remote-notification"]
      }
    },

    "android": {
      "package": "com.maksymstorozhuk.islamua",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0D1B2A"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.USE_EXACT_ALARM",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE",
        "android.permission.INTERNET"
      ]
    },

    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Islam UA потребує вашого місцезнаходження для точного часу молитов."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#D4A843",
          "sounds": ["./assets/audio/adhan.mp3"]
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "buildReactNativeFromSource": true,
            "deploymentTarget": "15.1"
          }
        }
      ],
      "./plugins/withPrayerWidget"
    ],

    "experiments": {
      "typedRoutes": true
    },

    "extra": {
      "appName": "Islam UA",
      "author": "Maksym Storozhuk",
      "organization": "Асоціація мусульман України",
      "eas": {
        "projectId": "2704fb21-8aab-4fac-ad9e-fc299ecd134b"
      }
    }
  }
}
