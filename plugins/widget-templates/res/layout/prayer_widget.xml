<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="18dp"
    android:theme="@style/Theme.AppWidget.IslamUA">

    <!-- ═══ TOP: live dot + "NEXT PRAYER" label ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <ImageView
            android:layout_width="7dp"
            android:layout_height="7dp"
            android:src="@drawable/live_dot"
            android:layout_marginEnd="8dp"
            android:contentDescription="@null" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/widget_next_prayer"
            android:textSize="10sp"
            android:textColor="#9DB4CC"
            android:textStyle="bold"
            android:letterSpacing="0.12" />
    </LinearLayout>

    <!-- ═══ MAIN: prayer name (large) + time (large) ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical|bottom"
        android:layout_marginBottom="4dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/prayerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Фаджр"
                android:textSize="34sp"
                android:textColor="#F0F7FF"
                android:textStyle="bold"
                android:includeFontPadding="false" />

            <TextView
                android:id="@+id/arabicName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="الفجر"
                android:textSize="18sp"
                android:textColor="#F0C860"
                android:layout_marginTop="-2dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/prayerTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="05:39"
            android:textSize="32sp"
            android:textColor="#F0F7FF" />
    </LinearLayout>

    <!-- ═══ COUNTDOWN PILL: "8г 49хв залишилось" ═══ -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/countdown_pill"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="7dp"
        android:paddingBottom="7dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="10dp">

        <TextView
            android:id="@+id/countdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="8г 49хв"
            android:textSize="13sp"
            android:textColor="#F0C860"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/widget_remaining"
            android:textSize="11sp"
            android:textColor="#9DB4CC" />
    </LinearLayout>

    <!-- ═══ PROGRESS BAR ═══ -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:progressDrawable="@drawable/progress_bar_gold"
        android:progress="22"
        android:max="100"
        android:layout_marginBottom="5dp" />

    <!-- ═══ FROM / TO labels: "Іша (20:49)  —  Фаджр (05:39)" ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/fromLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textSize="10sp"
            android:textColor="#9DB4CC" />

        <TextView
            android:id="@+id/toLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textSize="10sp"
            android:textColor="#9DB4CC"
            android:gravity="end" />
    </LinearLayout>

</LinearLayout>
