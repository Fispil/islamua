<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/calendarRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="16dp"
    android:theme="@style/Theme.AppWidget.IslamUA">

    <!-- Header: city + hijri -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">
        <TextView
            android:id="@+id/calendarCity"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Київ"
            android:textSize="13sp"
            android:textColor="#F0F7FF"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/calendarHijri"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="11sp"
            android:textColor="#D4A843" />
    </LinearLayout>

    <!-- Row 1 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="2dp"
        android:paddingBottom="2dp">
        <ImageView
            android:id="@+id/row1Indicator"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:src="@drawable/live_dot"
            android:layout_marginEnd="8dp"
            android:contentDescription="@null" />
        <TextView
            android:id="@+id/row1Name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:text="Фаджр"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#F0F7FF" />
        <TextView
            android:id="@+id/row1Arabic"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="الفجر"
            android:textSize="12sp"
            android:textColor="#9DB4CC" />
        <TextView
            android:id="@+id/row1Time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#F0F7FF" />
    </LinearLayout>

    <!-- Row 2 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="2dp"
        android:paddingBottom="2dp">
        <ImageView
            android:id="@+id/row2Indicator"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:src="@drawable/live_dot"
            android:layout_marginEnd="8dp"
            android:contentDescription="@null" />
        <TextView
            android:id="@+id/row2Name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:text="Зухр"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#F0F7FF" />
        <TextView
            android:id="@+id/row2Arabic"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="الظهر"
            android:textSize="12sp"
            android:textColor="#9DB4CC" />
        <TextView
            android:id="@+id/row2Time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#F0F7FF" />
    </LinearLayout>

    <!-- Row 3 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="2dp"
        android:paddingBottom="2dp">
        <ImageView
            android:id="@+id/row3Indicator"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:src="@drawable/live_dot"
            android:layout_marginEnd="8dp"
            android:contentDescription="@null" />
        <TextView
            android:id="@+id/row3Name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:text="Аср"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#F0F7FF" />
        <TextView
            android:id="@+id/row3Arabic"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="العصر"
            android:textSize="12sp"
            android:textColor="#9DB4CC" />
        <TextView
            android:id="@+id/row3Time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#F0F7FF" />
    </LinearLayout>

    <!-- Row 4 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="2dp"
        android:paddingBottom="2dp">
        <ImageView
            android:id="@+id/row4Indicator"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:src="@drawable/live_dot"
            android:layout_marginEnd="8dp"
            android:contentDescription="@null" />
        <TextView
            android:id="@+id/row4Name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:text="Магріб"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#F0F7FF" />
        <TextView
            android:id="@+id/row4Arabic"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="المغرب"
            android:textSize="12sp"
            android:textColor="#9DB4CC" />
        <TextView
            android:id="@+id/row4Time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#F0F7FF" />
    </LinearLayout>

    <!-- Row 5 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="2dp"
        android:paddingBottom="2dp">
        <ImageView
            android:id="@+id/row5Indicator"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:src="@drawable/live_dot"
            android:layout_marginEnd="8dp"
            android:contentDescription="@null" />
        <TextView
            android:id="@+id/row5Name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:text="Іша"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#F0F7FF" />
        <TextView
            android:id="@+id/row5Arabic"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="العشاء"
            android:textSize="12sp"
            android:textColor="#9DB4CC" />
        <TextView
            android:id="@+id/row5Time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#F0F7FF" />
    </LinearLayout>

</LinearLayout>
